# ============================================================
# Keycloak — Environment Configuration
# ============================================================

KEYCLOAK_VERSION=26.5.5

# ZeroTier IP of the host running Keycloak
KEYCLOAK_BIND_IP=10.155.38.139

# HTTP port (direct Keycloak, used internally / fallback)
KEYCLOAK_HTTP_PORT=8090

# HTTPS port exposed by Caddy reverse proxy
KEYCLOAK_HTTPS_PORT=8443

KEYCLOAK_MANAGEMENT_PORT=9000

# Use HTTPS hostname (via Caddy) for Microsoft OIDC compatibility
KEYCLOAK_HOSTNAME=https://10.155.38.139:8443

# Keycloak admin bootstrap credentials
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

# Keycloak Postgres DB
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-db
POSTGRES_PASSWORD=change-me-postgres

# ============================================================
# Realm + Client (used by Streamlit UI)
# ============================================================
KEYCLOAK_REALM=ckuens-platform
KEYCLOAK_CLIENT_ID=data-platform-ui
KEYCLOAK_CLIENT_SECRET=change-me-client-secret
# Streamlit UI redirect URI — HTTP is acceptable here since it is a local ZeroTier address
# (Microsoft OIDC redirect goes through Keycloak, not directly to Streamlit)
KEYCLOAK_REDIRECT_URI=http://10.155.38.139:8501

# ============================================================
# Microsoft Entra ID / Azure AD OIDC Identity Provider
# (configured as a Keycloak Identity Provider broker)
#
# Azure App Registration details:
#   App name:      Keycloak-ckuens
#   Client ID:     bb9a553b-3973-4fa7-8251-3df4b8710847
#   Tenant ID:     7a868a2c-2d6a-470b-aa53-e03cfe747558
#
# Azure Redirect URI to register:
#   https://10.155.38.139:8443/realms/ckuens-platform/broker/microsoft/endpoint
# ============================================================
MICROSOFT_TENANT_ID=7a868a2c-2d6a-470b-aa53-e03cfe747558
MICROSOFT_CLIENT_ID=bb9a553b-3973-4fa7-8251-3df4b8710847
MICROSOFT_CLIENT_SECRET=change-me-azure-client-secret

# The alias used when registering the IdP inside Keycloak admin console
# Must match the alias set in: Keycloak Admin > Identity Providers > Microsoft > Alias
MICROSOFT_IDP_ALIAS=microsoft
