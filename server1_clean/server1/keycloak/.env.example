# ============================================================
# Keycloak — Runtime Environment
# ============================================================

KEYCLOAK_VERSION=26.5.5

# ZeroTier IP of the host running Keycloak
KEYCLOAK_BIND_IP=10.155.38.139
KEYCLOAK_HTTP_PORT=8090
KEYCLOAK_MANAGEMENT_PORT=9000
KEYCLOAK_HOSTNAME=http://10.155.38.139:8090

# Keycloak admin bootstrap credentials
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

# Keycloak Postgres DB
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-db
POSTGRES_PASSWORD=change-me-postgres

# ============================================================
# Realm + Client (used by Streamlit UI)
# ============================================================
KEYCLOAK_REALM=ckuens-platform
KEYCLOAK_CLIENT_ID=data-platform-ui
KEYCLOAK_CLIENT_SECRET=change-me-client-secret
KEYCLOAK_REDIRECT_URI=http://10.155.38.139:8501

# ============================================================
# Microsoft Entra ID / Azure AD  OIDC Identity Provider
# (configured as a Keycloak Identity Provider broker)
# ============================================================
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret

# The alias used when registering the IdP inside Keycloak admin console
# This becomes the "kc_idp_hint" value in the login URL
MICROSOFT_IDP_ALIAS=microsoft
